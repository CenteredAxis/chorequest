# ChoreQuest Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# SQLite database file path
DB_PATH=./data/chorequest.db

# Photo upload directory
UPLOAD_DIR=./data/uploads

# Session secret - CHANGE THIS to a long random string in production!
SESSION_SECRET=change_this_to_a_long_random_secret_string

# Node environment
NODE_ENV=development
